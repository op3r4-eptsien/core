local plr = game.Players.LocalPlayer
local rs = game:GetService("RunService")

pcall(function() getgenv().loop:Disconnect() end)
pcall(function() plr.PlayerGui.m:Destroy() end)

local sg = Instance.new("ScreenGui", plr.PlayerGui)
sg.Name = "m"

local f = Instance.new("Frame", sg)
f.Size = UDim2.new(0,80,0,30)
f.Position = UDim2.new(0.5,-40,0.7,0)
f.BackgroundColor3 = Color3.fromRGB(67,67,67)
f.BorderSizePixel = 0
f.Active = true
f.Draggable = true

local btn = Instance.new("TextButton", f)
btn.Size = UDim2.new(1,0,1,0)
btn.BackgroundColor3 = Color3.fromRGB(127,127,127)
btn.BorderSizePixel = 0
btn.Text = "OFF"
btn.TextColor3 = Color3.fromRGB(255,255,255)
btn.TextSize = 14

local on = false
local seats = {}
local jail = Vector3.new(-930, 535.4, -960)

btn.MouseButton1Click:Connect(function()
    on = not on
    if on then
        btn.Text = "ON"
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        
        seats = {}
        local ac = workspace:FindFirstChild(plr.Name.." Aircraft")
        if ac then
            for _,v in pairs(ac:GetDescendants()) do
                if v.ClassName == "Seat" then
                    pcall(function() game.ReplicatedStorage.Remotes.UnanchorWelds:FireServer(v, "Break") end)
                    v.CanCollide = false
                    v.Massless = true
                    table.insert(seats, v)
                end
            end
        end

        getgenv().loop = rs.Heartbeat:Connect(function()
            if not on then return end
            local ac2 = workspace:FindFirstChild(plr.Name.." Aircraft")
            if not ac2 or #seats == 0 then return end

            local tgs = {}
            for _,p in pairs(game.Players:GetPlayers()) do
                if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    if p.Character.HumanoidRootPart.Position.Y < 10000 then
                        table.insert(tgs, p)
                    end
                end
            end
            if #tgs == 0 then return end

            local tm = tick()
            for i, s in pairs(seats) do
                if s and s.Parent then
                    if s.Occupant then
                        s.CFrame = CFrame.new(jail + Vector3.new(i*3,0,0))
                        s.Velocity = Vector3.zero
                    else
                        local tg = tgs[(i % #tgs) + 1].Character.HumanoidRootPart
                        local c = tg.Position + (tg.Velocity * 0.55)
                        
                        local y = 1 - (i / #seats) * 2
                        local r = math.sqrt(1 - math.abs(y*y))
                        local th = 2.39996 * i + (tm * 20)
                        local off = Vector3.new(math.cos(th)*r, y, math.sin(th)*r) * 3
                        
                        s.CFrame = CFrame.new(c + off, c)
                        s.Velocity = tg.Velocity
                    end
                end
            end
        end)
    else
        btn.Text = "OFF"
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        pcall(function() getgenv().loop:Disconnect() end)
    end
end)
